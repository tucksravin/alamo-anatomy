{
	"name": "sveltekit-prismic-starter-t-lemos",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "concurrently \"npm:vite:dev\" \"npm:slicemachine\" --prefix-colors blue,magenta",
		"vite:dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"lint": "prettier --check . --plugin prettier-plugin-svelte . && eslint .",
		"format": "prettier --write . --plugin prettier-plugin-svelte .",
		"test": "vitest run",
		"test:watch": "vitest",
		"slicemachine": "start-slicemachine"
	},
	"devDependencies": {
		"@slicemachine/adapter-sveltekit": "^0.3.36",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/kit": "^2.5.27",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/svelte": "^5.3.1",
		"concurrently": "^9.1.2",
		"eslint": "^9.17.0",
		"eslint-config-prettier": "^10.1.1",
		"eslint-plugin-svelte": "^3.1.0",
		"jsdom": "^28.1.0",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.2.6",
		"slice-machine-ui": "^2.11.1",
		"svelte": "^5.23.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.14",
		"typescript": "^5.9.3",
		"typescript-svelte-plugin": "^0.3.36",
		"vite": "^8.0.2",
		"vitest": "^4.1.1"
	},
	"type": "module",
	"dependencies": {
		"@prismicio/client": "^7.3.1",
		"@prismicio/svelte": "^2.0.0",
		"@tailwindcss/vite": "^4.1.4",
		"@zerodevx/svelte-img": "^2.1.2",
		"flatpickr": "^4.6.13",
		"svelte-gestures": "^5.0.7"
	},
	"packageManager": "pnpm@10.33.1",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp"
		]
	}
}
